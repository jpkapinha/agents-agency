# =============================================================================
# jpkapinha/agents-agency — Environment Configuration
#
# 1. Copy this file:  cp .env.example .env
# 2. Fill in every required value below
# 3. NEVER commit your .env file — it is gitignored
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — AI Routing
# All agents call models via OpenRouter. Get your key at openrouter.ai
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-YOUR_OPENROUTER_API_KEY_HERE

# -----------------------------------------------------------------------------
# REQUIRED — Discord Integration
# The Project Manager communicates with humans exclusively via Discord.
# Set up a Discord bot at discord.com/developers/applications
# -----------------------------------------------------------------------------
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE
DISCORD_GUILD_ID=YOUR_DISCORD_SERVER_ID_HERE
DISCORD_PM_CHANNEL_ID=YOUR_PM_CHANNEL_ID_HERE

# -----------------------------------------------------------------------------
# REQUIRED — Project Identity
# -----------------------------------------------------------------------------
# Your GitHub organization (used for repo references)
GITHUB_ORG=jpkapinha

# Short name for the current project (used in logs and Discord messages)
PROJECT_NAME=my-web3-project

# -----------------------------------------------------------------------------
# OPTIONAL — Cost Controls
# The agency will post a Discord warning when cumulative spend exceeds this
# -----------------------------------------------------------------------------
COST_WARNING_THRESHOLD_USD=5

# -----------------------------------------------------------------------------
# OPTIONAL — Private Web3 Skills Repository
# Cloned at startup via SSH deploy key (see secrets/git_deploy_key).
# Change this only if you fork the skills repo.
# -----------------------------------------------------------------------------
WEB3_SKILLS_REPO=git@github.com:protofire/web3-skills.git
